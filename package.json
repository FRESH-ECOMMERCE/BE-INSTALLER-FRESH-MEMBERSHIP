{
  "name": "notionclone",
  "version": "1.0.0",
  "description": "",
  "main": "server.ts",
  "scripts": {
    "build": "tsc",
    "start": "tsc && node ./build/server.js",
    "dev": "tsx watch . server.ts --ignore build --clear-screen=false",
    "migrate:up": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo",
    "seed": "npx sequelize-cli db:seed:all",
    "lint:fix": "eslint --fix ./*.ts",
    "test": "jest --testPathPattern=\"src/(services|utils|controllers|middlewares)/\" --testPathIgnorePatterns=\"build/\" --passWithNoTests"
  },
  "jest": {
    "testEnvironment": "node"
  },
  "keywords": [
    "express js"
  ],
  "author": "Misdar Manto",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.6",
    "cluster": "^0.7.7",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^10.0.0",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "http": "^0.0.1-security",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.10.0",
    "jest-mock-req-res": "^1.0.2",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.30.1",
    "morgan": "^1.10.1",
    "multer": "^1.4.4",
    "mysql2": "^2.3.3",
    "path": "^0.12.7",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.5",
    "swagger-autogen": "^2.23.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "uuid": "^8.3.2",
    "winston": "^3.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/preset-typescript": "^7.24.7",
